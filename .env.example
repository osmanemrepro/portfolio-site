# Database
PRISMA_DATABASE_URL=postgresql://user:password@localhost:5432/portfolio_db

# JWT Authentication
JWT_SECRET=your-jwt-secret-here-change-this

# Uploadthing File Storage (v7 format - base64 encoded JSON)
# Generate with: echo -n '{"apiKey":"YOUR_SECRET","appId":"YOUR_APP_ID","regions":["eu1"]}' | base64 -w 0
UPLOADTHING_TOKEN=your-uploadthing-token-here

# Optional: Spotify OAuth
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
