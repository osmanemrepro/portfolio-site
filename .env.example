# Database
PRISMA_DATABASE_URL=postgresql://user:password@localhost:5432/portfolio_db

# JWT Authentication
JWT_SECRET=your-jwt-secret-here-change-this

# Vercel Blob (automatically injected by Vercel — no manual setup needed)
# BLOB_READ_WRITE_TOKEN is auto-configured in Vercel Dashboard > Storage

# Optional: Spotify OAuth
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
